{
  "openapi": "3.0.3",
  "info": {
    "title": "Urja Meter Ops API",
    "description": "A clean REST API wrapper around the Urja Meter Ops portal, providing programmatic access to smart meter information.",
    "version": "1.0.0",
    "contact": {
      "name": "Flock Energy"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/api/meters": {
      "get": {
        "summary": "Search meters",
        "description": "Search for meters with pagination support",
        "operationId": "searchMeters",
        "tags": ["Meters"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Search query string",
            "schema": {
              "type": "string",
              "default": ""
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "description": "Meter search results from the portal"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/meters/{id}": {
      "get": {
        "summary": "Get meter by ID",
        "description": "Get detailed information for a specific meter, including details, energy data, and geolocation",
        "operationId": "getMeterById",
        "tags": ["Meters"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Meter ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "description": "Aggregated meter data including details, energy, and geolocation",
                      "properties": {
                        "meterDetails": {
                          "type": "object",
                          "description": "Basic meter information and installation details"
                        },
                        "energy": {
                          "type": "object",
                          "description": "Energy consumption data"
                        },
                        "geolocation": {
                          "type": "object",
                          "description": "Meter location information"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing meter ID",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "error": {
                      "type": "string",
                      "example": "Meter ID is required"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Meter not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/dts": {
      "get": {
        "summary": "Get distribution transformers",
        "description": "Get information about distribution transformers",
        "operationId": "getTransformers",
        "tags": ["Transformers"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "description": "Distribution transformer data from the portal"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Meters",
      "description": "Meter-related operations"
    },
    {
      "name": "Transformers",
      "description": "Distribution transformer operations"
    }
  ]
}
